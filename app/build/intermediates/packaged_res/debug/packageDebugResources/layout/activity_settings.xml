<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dialog_panel_background"
    android:orientation="vertical">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/settings_cancel"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:contentDescription="Close"
            android:src="@drawable/ic_close" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/settings_cancel"
            android:layout_toStartOf="@id/settings_done"
            android:gravity="start"
            android:paddingStart="16dp"
            android:text="Widget Settings"
            android:textColor="@color/button_create_bg"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/settings_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_create_button"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:text="Save"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="40dp">

            <!-- Display Section -->
            <include
                android:id="@+id/display_header"
                layout="@layout/component_section_header" />

            <include
                android:id="@+id/font_size_row"
                layout="@layout/component_settings_control" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="8dp"
                android:background="@color/outline_soft" />

            <include
                android:id="@+id/columns_row"
                layout="@layout/component_settings_control" />

            <!-- Active Categories Section -->
            <include
                android:id="@+id/categories_header"
                layout="@layout/component_section_header" />

            <LinearLayout
                android:id="@+id/category_checks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>