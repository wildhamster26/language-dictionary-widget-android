<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:colorAccent">@color/secondary</item>
    </style>

    <style name="DialogOverlayTheme" parent="@android:style/Theme.Material.Light.Dialog.Alert">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowCloseOnTouchOutside">true</item>
        <item name="android:backgroundDimAmount">0.18</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:colorAccent">@color/secondary</item>
        <item name="android:windowBackground">@drawable/bg_dialog_rounded</item>
    </style>

    <style name="RoundedDialogTheme" parent="@android:style/Theme.Material.Light.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_dialog_rounded</item>
        <item name="android:textColorPrimary">@color/button_create_bg</item>
        <item name="android:colorAccent">@color/button_create_bg</item>
    </style>

    <style name="PrimaryButton">
        <item name="android:background">@drawable/bg_primary_button</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="SecondaryButton">
        <item name="android:background">@drawable/bg_secondary_button</item>
        <item name="android:textColor">@color/button_create_bg</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="SmallSecondaryButton" parent="SecondaryButton">
        <item name="android:layout_height">40dp</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="DangerButton" parent="PrimaryButton">
        <item name="android:background">@drawable/bg_danger_button</item>
    </style>
</resources>
