<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/word_row_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false"
    android:orientation="horizontal"
    android:paddingBottom="4dp">

    <LinearLayout
        android:id="@+id/word_cell_1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="2dp"
        android:layout_weight="1"
        android:background="@drawable/word_item_background"
        android:minHeight="46dp"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/word_native_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollHorizontally="false"
            android:singleLine="false"
            android:textColor="@color/word_native"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/word_translation_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollHorizontally="false"
            android:singleLine="false"
            android:textColor="@color/word_translation"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/word_cell_2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"
        android:layout_weight="1"
        android:background="@drawable/word_item_background"
        android:minHeight="46dp"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/word_native_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollHorizontally="false"
            android:singleLine="false"
            android:textColor="@color/word_native"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/word_translation_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollHorizontally="false"
            android:singleLine="false"
            android:textColor="@color/word_translation"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/word_cell_3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"
        android:layout_weight="1"
        android:background="@drawable/word_item_background"
        android:minHeight="46dp"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/word_native_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollHorizontally="false"
            android:singleLine="false"
            android:textColor="@color/word_native"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/word_translation_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollHorizontally="false"
            android:singleLine="false"
            android:textColor="@color/word_translation"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/word_cell_4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:layout_weight="1"
        android:background="@drawable/word_item_background"
        android:minHeight="46dp"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/word_native_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollHorizontally="false"
            android:singleLine="false"
            android:textColor="@color/word_native"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/word_translation_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollHorizontally="false"
            android:singleLine="false"
            android:textColor="@color/word_translation"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
