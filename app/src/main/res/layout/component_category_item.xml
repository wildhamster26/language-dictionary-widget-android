<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_rounded_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <ImageView
        android:id="@+id/reorder_handle"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="12dp"
        android:src="@drawable/ic_reorder"
        android:contentDescription="@string/content_description_reorder" />

    <View
        android:id="@+id/folder_icon_container"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_folder_icon" />

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="-36dp"
        android:src="@drawable/ic_folder" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/category_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category Name"
            android:textColor="@color/word_native"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/word_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 Words"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageView
        android:id="@+id/delete_category"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_secondary_button"
        android:contentDescription="@string/action_delete"
        android:padding="10dp"
        android:src="@drawable/ic_delete"
        android:visibility="gone" />

    <CheckBox
        android:id="@+id/category_active_checkbox"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@drawable/checkbox_selector"
        android:button="@null" />

</LinearLayout>
