<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dialog_panel_background"
    android:orientation="vertical">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/settings_top_cancel"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:contentDescription="@string/content_description_close"
            android:src="@drawable/ic_close" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/title_widget_settings"
            android:textColor="@color/button_create_bg"
            android:textSize="22sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Tab Strip -->
    <LinearLayout
        android:id="@+id/settings_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tab_general"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:text="@string/tab_general"
                    android:textColor="@color/button_create_bg"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/tab_general_indicator"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/button_create_bg" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tab_language"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:text="@string/tab_language"
                    android:textColor="@color/text_hint"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/tab_language_indicator"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/button_create_bg"
                    android:visibility="invisible" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/outline_soft" />
    </LinearLayout>

    <!-- General Panel -->
    <ScrollView
        android:id="@+id/panel_general"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <include
                android:id="@+id/display_header"
                layout="@layout/component_section_header" />

            <include
                android:id="@+id/font_size_row"
                layout="@layout/component_settings_control" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="8dp"
                android:background="@color/outline_soft" />

            <include
                android:id="@+id/category_font_size_row"
                layout="@layout/component_settings_control" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="8dp"
                android:background="@color/outline_soft" />

            <include
                android:id="@+id/columns_row"
                layout="@layout/component_settings_control" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="8dp"
                android:background="@color/outline_soft" />

            <include
                android:id="@+id/sort_by_length_row"
                layout="@layout/component_settings_toggle" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="8dp"
                android:background="@color/outline_soft" />

            <include
                android:id="@+id/show_romanization_row"
                layout="@layout/component_settings_toggle" />

        </LinearLayout>
    </ScrollView>

    <!-- Language Panel -->
    <ScrollView
        android:id="@+id/panel_language"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <include
                android:id="@+id/translation_header"
                layout="@layout/component_section_header" />

            <include
                android:id="@+id/source_language_row"
                layout="@layout/component_settings_language" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="8dp"
                android:background="@color/outline_soft" />

            <include
                android:id="@+id/target_language_row"
                layout="@layout/component_settings_language" />

            <include
                android:id="@+id/downloaded_header"
                layout="@layout/component_section_header" />

            <LinearLayout
                android:id="@+id/downloaded_models_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/downloaded_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="2dp"
                android:text="@string/settings_downloaded_empty"
                android:textColor="@color/text_hint"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Welcome State -->
    <LinearLayout
        android:id="@+id/welcome_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/title_welcome_widget"
            android:textColor="@color/button_create_bg"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/welcome_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="@string/body_welcome_widget"
            android:textColor="@color/word_native"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/welcome_create_widget"
            style="@style/PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="20dp"
            android:text="@string/action_create_widget" />
    </LinearLayout>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/settings_bottom_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/settings_cancel"
                style="@style/SecondaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="@string/action_cancel" />

            <TextView
                android:id="@+id/settings_done"
                style="@style/PrimaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="@string/action_save" />
        </LinearLayout>

        <TextView
            android:id="@+id/privacy_policy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="48dp"
            android:gravity="center"
            android:text="@string/privacy_policy"
            android:textColor="@color/button_create_bg"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
