<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dialog_panel_background"
    android:orientation="vertical">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/settings_top_cancel"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:contentDescription="@string/content_description_close"
            android:src="@drawable/ic_close" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/title_widget_settings"
            android:textColor="@color/button_create_bg"
            android:textSize="22sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <!-- Display Section -->
            <include
                android:id="@+id/display_header"
                layout="@layout/component_section_header" />

            <include
                android:id="@+id/font_size_row"
                layout="@layout/component_settings_control" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="8dp"
                android:background="@color/outline_soft" />

            <include
                android:id="@+id/category_font_size_row"
                layout="@layout/component_settings_control" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="8dp"
                android:background="@color/outline_soft" />

            <include
                android:id="@+id/columns_row"
                layout="@layout/component_settings_control" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/settings_cancel"
                style="@style/SecondaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="@string/action_cancel" />

            <TextView
                android:id="@+id/settings_done"
                style="@style/PrimaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="@string/action_save" />
        </LinearLayout>

        <TextView
            android:id="@+id/privacy_policy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="48dp"
            android:gravity="center"
            android:text="@string/privacy_policy"
            android:textColor="@color/button_create_bg"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
