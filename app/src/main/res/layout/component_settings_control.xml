<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="12dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/control_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Label"
            android:textColor="@color/word_native"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/control_sublabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sublabel"
            android:textColor="@color/text_hint"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_control_box"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/control_decrement"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="—"
            android:textColor="@color/text_hint"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/control_value"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="2"
            android:textColor="@color/word_native"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/control_increment"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="+"
            android:textColor="@color/text_hint"
            android:textSize="18sp" />
    </LinearLayout>

</LinearLayout>