<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dialog_panel_background"
    android:orientation="vertical">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/add_word_top_cancel"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:contentDescription="@string/content_description_close"
            android:src="@drawable/ic_close" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/title_add_words"
            android:textColor="@color/button_create_bg"
            android:textSize="22sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Tab Strip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tab_words"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="@string/tab_words"
                android:textColor="@color/button_create_bg"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/tab_words_indicator"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/button_create_bg" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tab_categories"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="@string/tab_categories"
                android:textColor="@color/text_hint"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/tab_categories_indicator"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/button_create_bg"
                android:visibility="invisible" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/outline_soft" />

    <!-- Words Panel -->
    <ScrollView
        android:id="@+id/panel_words"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="@string/label_category"
                android:textColor="@color/section_header"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp">

                <Spinner
                    android:id="@+id/category_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="@string/label_word_pair"
                android:textColor="@color/section_header"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <EditText
                    android:id="@+id/native_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="@string/hint_native_word"
                    android:importantForAutofill="no"
                    android:inputType="textCapSentences"
                    android:textColor="@color/word_native"
                    android:textColorHint="@color/text_hint"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="8dp">

                <EditText
                    android:id="@+id/translation_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/hint_translated_word"
                    android:importantForAutofill="no"
                    android:inputType="textCapSentences"
                    android:textColor="@color/word_native"
                    android:textColorHint="@color/text_hint"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/translate_button"
                    style="@style/SmallSecondaryButton"
                    android:layout_width="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/action_translate" />
            </LinearLayout>

            <TextView
                android:id="@+id/translate_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/hint_set_target_language"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="@string/label_bulk_upload"
                android:textColor="@color/section_header"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_field"
                android:padding="16dp">

                <EditText
                    android:id="@+id/bulk_input"
                    android:layout_width="match_parent"
                    android:layout_height="128dp"
                    android:background="@null"
                    android:gravity="top"
                    android:hint="@string/hint_bulk_upload"
                    android:importantForAutofill="no"
                    android:inputType="textMultiLine"
                    android:textColor="@color/word_native"
                    android:textColorHint="@color/text_hint"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Categories Panel -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/panel_categories"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="20dp"
        android:visibility="gone" />

    <!-- Bottom Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp">

        <TextView
            android:id="@+id/add_word_cancel"
            style="@style/SecondaryButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:text="@string/action_cancel" />

        <TextView
            android:id="@+id/save_word"
            style="@style/PrimaryButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="@string/action_save" />
    </LinearLayout>

</LinearLayout>
